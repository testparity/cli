{
    "name": "testparity/parity",
    "description": "Structural parity and code coverage validation — pluggable rules, framework agnostic.",
    "keywords": ["testing", "coverage", "parity", "quality", "static-analysis", "cli"],
    "homepage": "https://testparity.com",
    "type": "library",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/testparity/cli/issues",
        "source": "https://github.com/testparity/cli"
    },
    "authors": [
        {
            "name": "Parity"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel-zero/framework": "^12.0.2",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "humbug/box": "^4.7",
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["parity"]
}
